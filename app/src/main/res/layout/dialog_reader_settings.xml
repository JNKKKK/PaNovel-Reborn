<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <cc.aoeiuv020.panovel.text.MaxHeightScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fadeScrollbars="false"
        android:scrollbarAlwaysDrawVerticalTrack="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

        <!-- ============ 字号 ============ -->
        <TextView
            style="@style/ReaderSettingsSection"
            android:text="@string/font_size" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxEms="4"
                android:minEms="4"
                android:singleLine="true"
                android:text="@string/message_font"
                android:textColor="@color/textBlack" />

            <SeekBar
                android:id="@+id/messageSizeSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="40" />

            <TextView
                android:id="@+id/messageSizeTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:maxEms="4"
                android:minEms="4"
                android:singleLine="true"
                android:textColor="@color/textBlack"
                tools:text="18sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxEms="4"
                android:minEms="4"
                android:singleLine="true"
                android:text="@string/body_font"
                android:textColor="@color/textBlack" />

            <SeekBar
                android:id="@+id/textSizeSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="40" />

            <TextView
                android:id="@+id/textSizeTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:maxEms="4"
                android:minEms="4"
                android:singleLine="true"
                android:textColor="@color/textBlack"
                tools:text="18sp" />

        </LinearLayout>

        <!-- ============ 亮度 ============ -->
        <TextView
            style="@style/ReaderSettingsSection"
            android:text="@string/brightness" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <SeekBar
                android:id="@+id/brightnessSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255" />

            <TextView
                android:id="@+id/tvBrightnessFollowSystem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:singleLine="true"
                android:text="@string/follow_system"
                android:textColor="@color/colorAccent"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- ============ 动画 ============ -->
        <TextView
            style="@style/ReaderSettingsSection"
            android:text="@string/animation" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxEms="4"
                android:minEms="4"
                android:singleLine="true"
                android:text="@string/animation_speed"
                android:textColor="@color/textBlack" />

            <SeekBar
                android:id="@+id/sbAnimationSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="199" />

            <TextView
                android:id="@+id/tvAnimationSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:maxEms="4"
                android:minEms="4"
                android:singleLine="true"
                android:textColor="@color/textBlack"
                tools:text="*0.8" />

        </LinearLayout>

        <RadioGroup
            android:id="@+id/rgAnimationMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbSimulation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="@string/simulation"
                android:textColor="@color/textBlack" />

            <RadioButton
                android:id="@+id/rbCover"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="@string/cover"
                android:textColor="@color/textBlack" />

            <RadioButton
                android:id="@+id/rbSlide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="@string/slide"
                android:textColor="@color/textBlack" />

            <RadioButton
                android:id="@+id/rbNone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="@string/none"
                android:textColor="@color/textBlack" />

            <RadioButton
                android:id="@+id/rbScroll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="@string/scroll"
                android:textColor="@color/textBlack" />
        </RadioGroup>

        <!-- ============ 配色 ============ -->
        <TextView
            style="@style/ReaderSettingsSection"
            android:text="@string/color_scheme" />

        <include
            android:id="@+id/colorScheme"
            layout="@layout/dialog_select_color_scheme" />

        <!-- ============ 正文间距 ============ -->
        <TextView
            style="@style/ReaderSettingsSection"
            android:text="@string/typesetting" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxEms="4"
                android:minEms="4"
                android:singleLine="true"
                android:text="@string/line_spacing"
                android:textColor="@color/textBlack" />

            <SeekBar
                android:id="@+id/lineSpacingSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="199" />

            <TextView
                android:id="@+id/lineSpacingTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:maxEms="4"
                android:minEms="4"
                android:singleLine="true"
                android:textColor="@color/textBlack"
                tools:text="2dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxEms="4"
                android:minEms="4"
                android:singleLine="true"
                android:text="@string/paragraph_spacing"
                android:textColor="@color/textBlack" />

            <SeekBar
                android:id="@+id/paragraphSpacingSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="199" />

            <TextView
                android:id="@+id/paragraphSpacingTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:maxEms="4"
                android:minEms="4"
                android:singleLine="true"
                android:textColor="@color/textBlack"
                tools:text="4dp" />

        </LinearLayout>

        <!-- ============ 正文边距 ============ -->
        <TextView
            style="@style/ReaderSettingsSection"
            android:text="@string/content_margins" />

        <include layout="@layout/novel_text_read_margins" />

        <!-- ============ 顶部信息栏（章节名/时间） ============ -->
        <TextView
            style="@style/ReaderSettingsSection"
            android:text="@string/top_info_bar" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabTopInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabGravity="fill"
            app:tabMode="fixed">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chapter_name" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time" />
        </com.google.android.material.tabs.TabLayout>

        <include
            android:id="@+id/topInfoMargins"
            layout="@layout/novel_text_read_margins" />

        <!-- ============ 底部信息栏（电池/页码/书名） ============ -->
        <TextView
            style="@style/ReaderSettingsSection"
            android:text="@string/bottom_info_bar" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabBottomInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabGravity="fill"
            app:tabMode="fixed">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/battery" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pagination" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/book_name" />
        </com.google.android.material.tabs.TabLayout>

        <include
            android:id="@+id/bottomInfoMargins"
            layout="@layout/novel_text_read_margins" />

        <!-- ============ 字体 ============ -->
        <TextView
            style="@style/ReaderSettingsSection"
            android:text="@string/font" />

        <RadioGroup
            android:id="@+id/rgFont"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbCustomFont"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="@string/custom_font"
                android:textColor="@color/textBlack" />

            <RadioButton
                android:id="@+id/rbDefaultFont"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="@string/default_font"
                android:textColor="@color/textBlack" />
        </RadioGroup>

        </LinearLayout>
    </cc.aoeiuv020.panovel.text.MaxHeightScrollView>

    <!-- 底部按钮栏：恢复默认 | 取消 | 应用 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btnRestoreDefault"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/restore_default" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnCancel"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:textColor="@color/colorAccent" />

        <Button
            android:id="@+id/btnApply"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/apply"
            android:textColor="@color/colorAccent" />

    </LinearLayout>

</LinearLayout>
